# MongoDB credentials (used by both mongo container and app connection string)
MONGO_USER=arecommerce_user
MONGO_PASSWORD=change_me_strong_password

# Administrative API key (passed in X-Admin-Api-Key header)
ADMIN_API_KEY=change_me_strong_admin_key

# Yandex Cloud Object Storage credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: override rate limits (defaults: admin=10 req/min, public=60 req/min)
# RATE_LIMIT_ADMIN_RPM=10
# RATE_LIMIT_PUBLIC_RPM=60
